# RAGFlow API Configuration
# Copy this file to .env and fill in your values

# RAGFLOW Server URL
RAGFLOW_API_URL=http://127.0.0.1

# RAGFlow API Key
RAGFLOW_API_KEY=ragflow-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Dataset IDs to search (JSON array format)
RAGFLOW_DATASET_IDS=["dataset-id-1", "dataset-id-2"]
